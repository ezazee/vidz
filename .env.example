# ─── DATABASE ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string.
# Cara dapat:
#   1. Buka https://neon.tech → sign up / login
#   2. Buat project baru → pilih region terdekat
#   3. Di dashboard project, klik "Connection Details"
#   4. Copy string "Connection string" format:
#      postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ─── INTERNAL API SECRET ──────────────────────────────────────────────────────
# Token untuk autentikasi antara GitHub Actions runner dan Next.js API.
# Cara dapat:
#   Generate string random panjang di terminal: openssl rand -hex 32
#   Simpan nilai yang sama di GitHub repo → Settings → Secrets → Actions → API_SECRET
API_SECRET=

# ─── APP BASE URL ────────────────────────────────────────────────────────────
# URL publik Next.js app ini — dipakai GitHub Actions untuk callback PATCH job status.
# Lokal: http://localhost:3000 | Production: https://nama-project.vercel.app
API_BASE_URL=

# ─── GITHUB ──────────────────────────────────────────────────────────────────
# GITHUB_TOKEN: github.com/settings/tokens → Generate → scope "repo" → copy token
# GITHUB_REPO: format "username/nama-repo"
GITHUB_TOKEN=
GITHUB_REPO=username/repo-name

# ─── AI ──────────────────────────────────────────────────────────────────────
# Base URL dan API key dari 9Router / AI gateway.
# AI_MODEL: nama model yang tersedia di gateway, misal: creavoo-combo
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# ─── TTS (ElevenLabs) ────────────────────────────────────────────────────────
# ElevenLabs untuk generate voice narasi per scene.
# Cara dapat: elevenlabs.io → Profile → API Key
# TTS_VOICE: voice ID atau nama, misal: id-ID-ArdiNeural
ELEVENLABS_API_KEY=
TTS_VOICE=

# ─── BLOB STORAGE ────────────────────────────────────────────────────────────
# Vercel Blob untuk menyimpan hasil render video dan gambar.
# Cara dapat: Vercel dashboard → project → Storage → Create Blob → copy token
BLOB_READ_WRITE_TOKEN=
